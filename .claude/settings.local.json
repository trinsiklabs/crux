          {
            "type": "command",
            "command": "PYTHONPATH=/home/key/.crux /home/key/.crux/.venv/bin/python -m scripts.lib.crux_hook_runner SessionStart"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "",
