#!/bin/bash
set -euo pipefail

###############################################################################
# Crux CLI — Wrapper for the Crux self-improving AI operating system
###############################################################################

VERSION="0.1.0"

# Resolve CRUX_DIR: env var > symlink target > script location
resolve_crux_dir() {
    if [ -n "${CRUX_DIR:-}" ]; then
        echo "$CRUX_DIR"
        return
    fi

    # Follow symlink to find repo
    local script_path
    script_path="$(readlink -f "$0" 2>/dev/null || realpath "$0" 2>/dev/null || echo "$0")"
    local bin_dir
    bin_dir="$(cd "$(dirname "$script_path")" && pwd)"
    echo "$(dirname "$bin_dir")"
}

CRUX_DIR="$(resolve_crux_dir)"

# Color codes
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
BOLD='\033[1m'
NC='\033[0m'

success() { echo -e "${GREEN}✓${NC} $1"; }
error()   { echo -e "${RED}✗${NC} $1"; }
info()    { echo -e "${BLUE}ℹ${NC} $1"; }
warn()    { echo -e "${YELLOW}⚠${NC} $1"; }

###############################################################################
# crux setup
###############################################################################
cmd_setup() {
    if [ ! -f "$CRUX_DIR/setup.sh" ]; then
        error "setup.sh not found in $CRUX_DIR"
        exit 1
    fi
    exec bash "$CRUX_DIR/setup.sh" "$@"
}

###############################################################################
# crux update
###############################################################################
cmd_update() {
    info "Updating Crux from $(cd "$CRUX_DIR" && git remote get-url origin 2>/dev/null || echo 'local repo')..."

    cd "$CRUX_DIR"

    # Check for local changes
    if ! git diff --quiet 2>/dev/null; then
        warn "You have local changes in $CRUX_DIR"
        echo -e "  Run ${BOLD}git stash${NC} first, or ${BOLD}crux update --force${NC} to overwrite."
        if [ "${1:-}" != "--force" ]; then
            exit 1
        fi
        warn "Force updating (local changes will be preserved via stash)..."
        git stash
    fi

    # Pull latest
    local branch
    branch="$(git rev-parse --abbrev-ref HEAD)"
    info "Pulling latest from $branch..."
    git pull --rebase origin "$branch"

    # Pop stash if we stashed
    if git stash list | grep -q "stash@{0}"; then
        info "Re-applying local changes..."
        git stash pop || warn "Stash pop had conflicts — resolve manually"
    fi

    # Re-run setup in update mode (skip interactive steps, refresh symlinks)
    info "Refreshing installation..."
    bash "$CRUX_DIR/setup.sh" --update

    success "Crux updated to $(git rev-parse --short HEAD)"
}

###############################################################################
# crux doctor — health check
###############################################################################
cmd_doctor() {
    echo -e "${BOLD}Crux Health Check${NC}\n"

    local issues=0

    # Check Crux repo
    if [ -d "$CRUX_DIR/.git" ]; then
        success "Crux repo: $CRUX_DIR ($(cd "$CRUX_DIR" && git rev-parse --short HEAD))"
    else
        error "Crux repo not found at $CRUX_DIR"
        issues=$((issues + 1))
    fi

    # Check Ollama
    if command -v ollama &>/dev/null; then
        if curl -s http://localhost:11434/api/tags &>/dev/null; then
            success "Ollama: running"
        else
            warn "Ollama: installed but not running"
            issues=$((issues + 1))
        fi
    else
        error "Ollama: not installed"
        issues=$((issues + 1))
    fi

    # Check OpenCode
    if command -v opencode &>/dev/null; then
        success "OpenCode: $(opencode --version 2>/dev/null || echo 'installed')"
    else
        error "OpenCode: not installed"
        issues=$((issues + 1))
    fi

    # Check config directory
    local config_dir="$HOME/.config/opencode"
    if [ -d "$config_dir" ]; then
        success "Config dir: $config_dir"
    else
        error "Config dir missing: $config_dir"
        issues=$((issues + 1))
    fi

    # Check symlinks
    local broken=0
    for dir in modes plugins tools commands; do
        if [ -L "$config_dir/$dir" ]; then
            if [ -d "$config_dir/$dir" ]; then
                local target
                target="$(readlink "$config_dir/$dir")"
                success "Symlink $dir → $target"
            else
                error "Broken symlink: $config_dir/$dir"
                broken=$((broken + 1))
            fi
        elif [ -d "$config_dir/$dir" ]; then
            warn "$dir: regular directory (not symlinked to repo — won't auto-update)"
        else
            error "$dir: missing"
            issues=$((issues + 1))
        fi
    done

    if [ "$broken" -gt 0 ]; then
        issues=$((issues + broken))
        echo ""
        warn "Broken symlinks detected. Run ${BOLD}crux setup${NC} to fix."
    fi

    # Check Python scripts
    if [ -d "$config_dir/scripts/lib" ]; then
        local py_count
        py_count=$(find "$config_dir/scripts/lib" -name "*.py" | wc -l | tr -d ' ')
        success "Python scripts: $py_count files"
    else
        warn "Python scripts not installed"
        issues=$((issues + 1))
    fi

    # Check models
    if command -v ollama &>/dev/null && curl -s http://localhost:11434/api/tags &>/dev/null; then
        for model in crux-think crux-chat; do
            if ollama list 2>/dev/null | grep -q "$model"; then
                success "Model: $model"
            else
                warn "Model not found: $model"
                issues=$((issues + 1))
            fi
        done
    fi

    echo ""
    if [ "$issues" -eq 0 ]; then
        success "All checks passed"
    else
        warn "$issues issue(s) found"
    fi
}

###############################################################################
# crux status — runtime insight
###############################################################################
cmd_status() {
    local project_dir="${CRUX_PROJECT:-$(pwd)}"
    local home_dir="${CRUX_HOME:-$HOME}"
    local python_path

    # Find Python
    python_path="$(command -v python3 2>/dev/null || command -v python 2>/dev/null)"
    if [ -z "$python_path" ]; then
        error "Python not found"
        exit 1
    fi

    cd "$CRUX_DIR"

    echo -e "${BOLD}Crux Status${NC}\n"
    $python_path -c "
import sys
sys.path.insert(0, '.')
from scripts.lib.crux_status import get_status, format_status, verify_health, generate_findings, format_findings

status = get_status(project_dir='$project_dir', home='$home_dir')
print(format_status(status))
print()

report = verify_health(project_dir='$project_dir', home='$home_dir')
print('HEALTH CHECKS')
print()
for label, checks in [('Static', report['static']), ('Liveness', report['liveness'])]:
    print(f'  {label}')
    for c in checks:
        mark = '\033[0;32m✓\033[0m' if c['passed'] else '\033[0;31m✗\033[0m'
        print(f'    {mark} {c[\"name\"]}: {c[\"message\"]}')
    print()

s = report['summary']
if s['all_passed']:
    print(f'\033[0;32m✓\033[0m All {s[\"total\"]} checks passed')
else:
    print(f'\033[1;33m⚠\033[0m {s[\"passed\"]}/{s[\"total\"]} checks passed ({s[\"failed\"]} failed)')

print()
findings = generate_findings(status, report)
print(format_findings(findings))
"
}

###############################################################################
# crux switch — switch active AI tool
###############################################################################
cmd_switch() {
    local target="${1:-""}"
    local project_dir="${CRUX_PROJECT:-$(pwd)}"
    local home_dir="${CRUX_HOME:-$HOME}"

    if [ -z "$target" ]; then
        echo "Usage: crux switch <tool>"
        echo "Supported tools: opencode, claude-code, cursor, windsurf"
        exit 1
    fi

    local python_path
    python_path="$(command -v python3 2>/dev/null || command -v python 2>/dev/null)"
    if [ -z "$python_path" ]; then
        error "Python not found"
        exit 1
    fi

    cd "$CRUX_DIR"

    $python_path -c "
import sys, json
sys.path.insert(0, '.')
from scripts.lib.crux_switch import switch_tool

result = switch_tool(
    target_tool='$target',
    project_dir='$project_dir',
    home='$home_dir',
)

if not result.success:
    print(f'\033[0;31mError:\033[0m {result.error}')
    sys.exit(1)

from_label = result.from_tool or 'none'
print(f'\033[0;32m✓\033[0m Switched: {from_label} → {result.to_tool}')
if result.items_synced:
    for item in result.items_synced:
        print(f'  → {item}')
print()
print(f'Open {result.to_tool} in your project directory to continue.')
"
}

###############################################################################
# crux bip — build-in-public
###############################################################################
cmd_bip() {
    local project_dir="${CRUX_PROJECT:-$(pwd)}"
    local home_dir="${CRUX_HOME:-$HOME}"
    local python_path
    python_path="$(command -v python3 2>/dev/null || command -v python 2>/dev/null)"
    if [ -z "$python_path" ]; then
        error "Python not found"
        exit 1
    fi

    cd "$CRUX_DIR"

    # Parse flags
    local platform="x"
    local force="False"
    local show_status="false"
    while [ $# -gt 0 ]; do
        case "$1" in
            --platform) platform="$2"; shift 2 ;;
            --force)    force="True"; shift ;;
            --status)   show_status="true"; shift ;;
            *)          shift ;;
        esac
    done

    if [ "$show_status" = "true" ]; then
        $python_path -c "
import sys
sys.path.insert(0, '.')
from scripts.lib.crux_mcp_handlers import handle_bip_status
import json

result = handle_bip_status(project_dir='$project_dir')
print('Build-in-Public Status')
print()
print(f'  Commits since last post:      {result[\"commits_since_last_post\"]}')
print(f'  Interactions since last post:  {result[\"interactions_since_last_post\"]}')
print(f'  Tokens since last post:        {result[\"tokens_since_last_post\"]}')
print(f'  Posts today:                   {result[\"posts_today\"]}')
print(f'  Cooldown:                      {\"ready\" if result[\"cooldown_ok\"] else \"waiting\"}')
print(f'  Last queued:                   {result[\"last_queued_at\"] or \"never\"}')
print(f'  Total posts:                   {result[\"total_posts\"]}')
print()
thresholds = result['thresholds']
print(f'  Thresholds — commits: {thresholds[\"commits\"]}, interactions: {thresholds[\"interactions\"]}, tokens: {thresholds[\"tokens\"]}')
if result['recent_posts']:
    print()
    print('  Recent posts:')
    for p in result['recent_posts']:
        print(f'    {p[\"source\"]}: {p[\"preview\"]}')
"
        return
    fi

    $python_path -c "
import sys
sys.path.insert(0, '.')
from scripts.lib.crux_mcp_handlers import handle_bip_generate

result = handle_bip_generate(
    project_dir='$project_dir',
    home='$home_dir',
    platform='$platform',
    force=$force,
)

if result['status'] == 'skipped':
    print(f'\033[1;33m⚠\033[0m No post triggered: {result[\"reason\"]}')
    state = result['state']
    print(f'  Commits: {state[\"commits\"]}, Interactions: {state[\"interactions\"]}, Tokens: {state[\"tokens\"]}')
    print(f'  Last queued: {state[\"last_queued_at\"] or \"never\"}')
    sys.exit(0)

print('\033[0;32m✓\033[0m Draft material ready')
print(f'  Trigger: {result[\"trigger_reason\"]}')
print(f'  Platform: {result[\"platform\"]}')
ctx = result['context']
print(f'  Unposted commits: {len(ctx[\"unposted_commits\"])}')
if ctx['corrections']:
    print(f'  Corrections: {len(ctx[\"corrections\"])}')
if ctx['knowledge_entries']:
    print(f'  Knowledge: {len(ctx[\"knowledge_entries\"])} entries')
print()
print('Use the bip_generate MCP tool in your AI session to generate and approve a draft.')
"
}

###############################################################################
# crux version
###############################################################################
cmd_version() {
    echo "crux $VERSION"
    if [ -d "$CRUX_DIR/.git" ]; then
        echo "repo: $(cd "$CRUX_DIR" && git rev-parse --short HEAD) ($(cd "$CRUX_DIR" && git log -1 --format='%ci' | cut -d' ' -f1))"
    fi
}

###############################################################################
# crux help
###############################################################################
cmd_help() {
    cat <<EOF
${BOLD}Crux${NC} — Self-improving AI operating system

${BOLD}Usage:${NC}
  crux <command> [options]

${BOLD}Commands:${NC}
  status      Show runtime status and run all health + liveness checks
  switch      Switch to a different AI tool (generates configs, updates session)
  bip         Build-in-public: check triggers, gather content, show status
  setup       Run the interactive setup wizard
  update      Pull latest changes and refresh installation
  doctor      Run infrastructure health checks (Ollama, OpenCode, symlinks)
  version     Show version information
  help        Show this help message

${BOLD}Switch:${NC}
  crux switch opencode    Generate OpenCode configs and switch
  crux switch cursor      Generate .cursor/rules/ + .cursor/mcp.json
  crux switch windsurf    Generate .windsurf/rules/ + .windsurf/mcp.json
  crux switch claude-code Generate Claude Code hooks + MCP config

${BOLD}Setup Options:${NC}
  crux setup              Full interactive setup
  crux setup --update     Non-interactive refresh (symlinks, scripts)

${BOLD}Note:${NC}
  Knowledge ingestion moved to key-ops: use 'onelist-ingest' instead of 'crux ingest'

${BOLD}Build-in-Public:${NC}
  crux bip                Check triggers and show gathered material
  crux bip --status       Show BIP state (counters, cooldown, recent posts)
  crux bip --force        Bypass cooldown and thresholds
  crux bip --platform x   Target specific platform (x, reddit, blog)

${BOLD}Update Options:${NC}
  crux update             Pull and refresh (fails if local changes)
  crux update --force     Stash local changes, pull, and refresh

${BOLD}Environment:${NC}
  CRUX_DIR    Override the Crux repository location
              Default: auto-detected from this script's location

${BOLD}Getting Started:${NC}
  git clone https://github.com/trinsiklabs/crux.git ~/.crux
  cd ~/.crux && crux setup

EOF
}

###############################################################################
# Main dispatch
###############################################################################
case "${1:-help}" in
    ingest)
        warn "The 'ingest' command has been moved to key-ops domain."
        info "Use 'onelist-ingest' instead (PLAN-372)"
        exit 1
        ;;
    status)  cmd_status ;;
    switch)  shift; cmd_switch "$@" ;;
    bip)     shift; cmd_bip "$@" ;;
    setup)   shift; cmd_setup "$@" ;;
    update)  shift; cmd_update "$@" ;;
    doctor)  cmd_doctor ;;
    version) cmd_version ;;
    help|--help|-h) cmd_help ;;
    *)
        error "Unknown command: $1"
        echo "Run 'crux help' for usage."
        exit 1
        ;;
esac
