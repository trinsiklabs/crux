---
layout: base.njk
title: blog - crux
description: build-in-public log from building crux
pagination:
  data: collections.post
  size: 10
  reverse: true
  alias: posts
permalink: "blog/{% if pagination.pageNumber > 0 %}page/{{ pagination.pageNumber + 1 }}/{% endif %}index.html"
---

<h1>build log</h1>

<ul class="post-list blog-index">
{% for post in posts %}
  <li class="post-item">
    <h2><a href="{{ post.url }}">{{ post.data.title }}</a></h2>
    <time datetime="{{ post.date | htmlDateString }}">{{ post.date | readableDate }}</time>
    {% if post.data.summary %}
    <p>{{ post.data.summary }}</p>
    {% endif %}
  </li>
{% else %}
  <li>no posts yet.</li>
{% endfor %}
</ul>

{% if pagination.pages.length > 1 %}
<nav class="pagination" aria-label="Blog pagination">
  <ul>
    {% if pagination.href.previous %}
    <li><a href="{{ pagination.href.previous }}">&larr; newer posts</a></li>
    {% endif %}

    <li class="pagination-info">
      page {{ pagination.pageNumber + 1 }} of {{ pagination.pages.length }}
    </li>

    {% if pagination.href.next %}
    <li><a href="{{ pagination.href.next }}">older posts &rarr;</a></li>
    {% endif %}
  </ul>
</nav>
{% endif %}
